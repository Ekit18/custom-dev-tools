{
  "name": "shopify-oauth-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run pg:generate && npm run mongo:generate && next build",
    "start": "next start",
    "lint": "biome check",
    "setup:dev": "npm run pg:migrate:dev",
    "postinstall": "npm run pg:generate && npm run mongo:generate",
    "setup": "npm run pg:migrate && npm run mongo:generate",
    "pg:migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "pg:migrate": "prisma migrate deploy --schema=prisma/schema.prisma",
    "pg:generate": "prisma generate --schema=prisma/schema.prisma",
    "mongo:generate": "prisma generate --schema=prisma-mongo/schema.prisma",
    "mongo:push": "prisma db push --schema=prisma-mongo/schema.prisma",
    "format": "biome format --write",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@graphiql/toolkit": "^0.11.3",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/material-nextjs": "^7.3.7",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.1.0",
    "graphiql": "^5.2.2",
    "graphql": "^16.12.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "next": "16.1.6",
    "prisma": "5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/csv-parse": "^1.1.12",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
